{
  "name": "raqam",
  "version": "0.4.2",
  "description": "The definitive React number input: live formatting, full i18n, headless, accessible",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "sideEffects": [
    "./dist/locales/*.js",
    "./dist/locales/*.cjs",
    "./dist/chunk-*.js",
    "./dist/chunk-*.cjs"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "47vigen",
  "license": "MIT",
  "homepage": "https://raqam.47vigen.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/47vigen/raqam.git"
  },
  "bugs": {
    "url": "https://github.com/47vigen/raqam/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core.d.ts"
      ],
      "react": [
        "./dist/react.d.ts"
      ],
      "locales": [
        "./dist/locales/index.d.ts"
      ],
      "locales/*": [
        "./dist/locales/*.d.ts"
      ],
      "server": [
        "./dist/core.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./locales": {
      "import": {
        "types": "./dist/locales/index.d.ts",
        "default": "./dist/locales/index.js"
      },
      "require": {
        "types": "./dist/locales/index.d.cts",
        "default": "./dist/locales/index.cjs"
      }
    },
    "./locales/*": {
      "import": {
        "types": "./dist/locales/*.d.ts",
        "default": "./dist/locales/*.js"
      },
      "require": {
        "types": "./dist/locales/*.d.cts",
        "default": "./dist/locales/*.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "prepare": "husky",
    "size": "size-limit",
    "publint": "publint",
    "test:e2e": "playwright test -c playwright-ct.config.ts",
    "test:e2e:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:e2e:debug": "playwright test -c playwright-ct.config.ts --headed --project=chromium",
    "docs:dev": "pnpm --filter raqam-docs dev",
    "docs:build": "pnpm --filter raqam-docs build",
    "release:beta": "changeset version --snapshot beta && changeset publish --tag beta"
  },
  "engines": {
    "node": ">=20.9"
  },
  "keywords": [
    "react",
    "number",
    "input",
    "formatting",
    "i18n",
    "intl",
    "headless",
    "accessible",
    "currency",
    "spinbutton"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@playwright/experimental-ct-react": "^1.61.1",
    "@playwright/test": "^1.61.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "chromatic": "^17.7.1",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "size-limit": "^12.1.0",
    "storybook": "^10.4.6",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
