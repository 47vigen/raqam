{
  "name": "raqam",
  "version": "0.2.3",
  "description": "The definitive React number input: live formatting, full i18n, headless, accessible",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "47vigen",
  "license": "MIT",
  "homepage": "https://47vigen.github.io/raqam",
  "repository": {
    "type": "git",
    "url": "https://github.com/47vigen/raqam"
  },
  "bugs": {
    "url": "https://github.com/47vigen/raqam/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "typesVersions": {
    "*": {
      "core": [
        "./dist/core.d.ts"
      ],
      "react": [
        "./dist/react.d.ts"
      ],
      "locales/*": [
        "./dist/locales/*.d.ts"
      ],
      "server": [
        "./dist/core.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./locales/*": {
      "import": {
        "types": "./dist/locales/*.d.ts",
        "default": "./dist/locales/*.js"
      },
      "require": {
        "types": "./dist/locales/*.d.cts",
        "default": "./dist/locales/*.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/core.d.ts",
        "default": "./dist/core.js"
      },
      "require": {
        "types": "./dist/core.d.cts",
        "default": "./dist/core.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "prepare": "husky",
    "size": "size-limit",
    "publint": "publint",
    "test:e2e": "playwright test -c playwright-ct.config.ts",
    "test:e2e:ui": "playwright test -c playwright-ct.config.ts --ui",
    "test:e2e:debug": "playwright test -c playwright-ct.config.ts --headed --project=chromium",
    "docs:dev": "cd docs && pnpm astro dev",
    "docs:build": "pnpm build && cd docs && pnpm astro build",
    "release:beta": "changeset version --snapshot beta && changeset publish --tag beta"
  },
  "keywords": [
    "react",
    "number",
    "input",
    "formatting",
    "i18n",
    "intl",
    "headless",
    "accessible",
    "currency",
    "spinbutton"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@playwright/experimental-ct-react": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-small-lib": "^11.1.6",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "chromatic": "^11.0.0",
    "husky": "^9.1.7",
    "jest-axe": "^9.0.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.0",
    "publint": "^0.2.12",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.72.1",
    "size-limit": "^11.1.6",
    "storybook": "^10.3.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
